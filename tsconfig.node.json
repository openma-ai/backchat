{
  "compilerOptions": {
    "composite": true,
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "target": "ES2022",
    "lib": ["ES2023"],
    "types": ["node"],
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "verbatimModuleSyntax": true,
    "isolatedModules": true,
    "outDir": "out/_node",
    "rootDir": ".",
    "paths": {
      "@shared/*": ["./src/shared/*"],
      "@acp/*": ["./packages/acp/src/*"]
    }
  },
  "include": [
    "src/main/**/*.ts",
    "src/preload/**/*.ts",
    "src/shared/**/*.ts",
    "packages/acp/src/**/*.ts",
    "electron.vite.config.ts"
  ]
}
