# node-pty (and any other native module that uses prebuild-install /
# node-pre-gyp / @mapbox/node-pre-gyp) reads these to pick the right
# binary. Without them, the prebuild script downloads the binary for
# the local Node binary's ABI, which is NOT the one Electron embeds —
# the require() inside the renderer/main process then crashes with
# "NODE_MODULE_VERSION mismatch".
#
# `target` follows the electron major. If you bump electron in
# devDependencies, bump this. `target_arch` is intentionally NOT set —
# prebuild-install reads `process.arch` per platform and downloads
# the right slice; pinning it would break Windows/Linux contributors.
runtime=electron
target=42.3.1
disturl=https://electronjs.org/headers
build_from_source=false
